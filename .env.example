# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# API Keys para os modelos de IA
GEMINI_API_KEY=sua_chave_aqui
DEEPSEEK_API_KEY=sua_chave_opcional_aqui
OPENAI_API_KEY=sua_chave_dalle_aqui_opcional_key_here
DEFAULT_PROVIDER=gemini

# Agent Loop
MAX_ITERATIONS=5
PIPELINE_TIMEOUT_MS=300000

# Memory
MAX_CONTEXT_TOKENS=8000
MEMORY_WINDOW_SIZE=20
DB_PATH=./data/sronic.db

# TTS
TTS_VOICE=pt-BR-ThalitaMultilingualNeural

# Logging
LOG_DIR=./data/logs
LOG_MAX_SIZE_MB=50

# Heartbeat
HEARTBEAT_INTERVAL_MS=300000
HEARTBEAT_MEMORY_THRESHOLD_MB=1024

# Scheduler
SCHEDULER_ENABLED=true

# Web Search (Tavily)
TAVILY_API_KEY=tvly_your_api_key_here
